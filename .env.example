# Local SQLite (Phase 1 dev)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production / Railway)
# DATABASE_URL="postgresql://user:password@host:5432/clinivore"

# NextAuth (required)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AI Provider: mock | openai | azure_openai
AI_PROVIDER=mock

# Only required if AI_PROVIDER is openai or azure_openai
AI_API_KEY=
AI_MODEL=gpt-4o

# IMPORTANT HIPAA SAFETY CONTROL
# Set to true ONLY if you have a BAA with your AI vendor and are in a compliant environment
# When false, only displayName and internalId are sent (no other PHI)
ALLOW_PHI_TO_AI=false

# App
NEXT_PUBLIC_APP_NAME=Clinivore
